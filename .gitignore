# ============================================================
# Terraform
# ============================================================

# プロバイダプラグインのバイナリ（大容量・再取得可能）
.terraform/

# ステートファイル（シークレットを含む・S3 バックエンドで管理）
*.tfstate
*.tfstate.backup

# プランファイル（バイナリ・シークレットを含む可能性あり）
*.tfplan

# 変数ファイル（DB パスワード・API キー等のシークレットを含む）
terraform.tfvars
terraform.tfvars.json
*.auto.tfvars
*.auto.tfvars.json

# Terraform が生成するオーバーライドファイル
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# クラッシュログ
crash.log
crash.*.log

# ============================================================
# 注意: .terraform.lock.hcl はコミット対象
# プロバイダバージョンを固定するロックファイル（package-lock.json 相当）
# ============================================================

# ============================================================
# OS
# ============================================================
.DS_Store
Thumbs.db

# ============================================================
# エディタ・IDE
# ============================================================
.vscode/
.idea/
*.swp
*.swo
